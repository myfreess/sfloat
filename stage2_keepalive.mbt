///|
// Stage 2 primitives are private until arithmetic ports consume them. Keep
// `moon check` warning-clean without exposing implementation helpers.
fn init {
  ignore(uint128_zero())
  let a = { hi: 1UL, lo: 0UL }
  let b = { hi: 0UL, lo: 1UL }
  ignore(uint128_is_zero(a))
  ignore(eq128(a, b))
  ignore(le128(b, a))
  ignore(lt128(b, a))
  ignore(add128(a, b))
  ignore(sub128(a, b))
  ignore(neg128(b))
  ignore(short_shift_left128(b, 1))
  ignore(short_shift_right128(a, 1))
  ignore(add128_m(a, b))
  ignore(sub128_m(a, b))
  ignore(negx128_m(b))
  ignore(shift_left128_m(b, 64))
  ignore(short_shift_right128_m(a, 64))
  ignore(mul64_to_128(3UL, 5UL))
  ignore(count_leading_zeros8(1U))
  ignore(count_leading_zeros16(1))
  ignore(count_leading_zeros32(1U))
  ignore(count_leading_zeros64(1UL))
  ignore(shift_right_jam32(1U, 1))
  ignore(short_shift_right_jam64(1UL, 1))
  ignore(shift_right_jam64(1UL, 1))
  ignore(short_shift_right_jam64_extra(1UL, 0UL, 1))
  ignore(shift_right_jam64_extra(1UL, 0UL, 65))
  ignore(short_shift_right_jam128(a, 1))
  ignore(shift_right_jam128(a, 65))
  ignore(shift_right_jam128_m(a, 65))
  ignore(approx_recip_1k0(0))
  ignore(approx_recip_1k1(0))
  ignore(approx_recip32_1(0x80000000U))
  ignore(approx_recip_sqrt_1k0(0))
  ignore(approx_recip_sqrt_1k1(0))
  ignore(approx_recip_sqrt32_1(true, 0x80000000U))
}
