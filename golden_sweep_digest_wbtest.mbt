    0x943CF28841434E75UL,
  )
}

///|
fn sweep_digest_random_f16_f16_add_x86_8086_sse() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  let mut rng = 0x000000005F0F7A7CUL
  for index in 0..<65536 {
    let rounding = sweep_rounding4(index % 4)
    let tininess = sweep_tininess(index / 4 % 2)
    let context = sweep_context(0, rounding, tininess)
    rng = sweep_lcg_next(rng)
    let a_bits : UInt16 = (rng & 0xFFFFUL).to_uint16()
    rng = sweep_lcg_next(rng)
    let b_bits : UInt16 = (rng & 0xFFFFUL).to_uint16()
    let result = f16_add(
      context,
      F16::from_bits(a_bits),
      F16::from_bits(b_bits),
    )
    hash = sweep_mix(hash, result.value.to_bits().to_uint64())
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

///|
test "golden sweep digest random_f16_f16_add_x86_8086_sse" {
  @debug.assert_eq(
    sweep_digest_random_f16_f16_add_x86_8086_sse(),
    0x9C84F213F6BE957DUL,
  )
}

