///|
fn sweep_digest_edge_f16_f16_to_ui32_riscv() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<216 {
    let mode_index = index / 18
    let input_index = index % 18
    let rounding = sweep_rounding6(mode_index / 2)
    let tininess = AfterRounding
    let exact = mode_index % 2 == 1
    let context = sweep_context(1, rounding, tininess)
    let a_bits = sweep_edge_f16(input_index)
    let result = f16_to_ui32(context, F16::from_bits(a_bits), rounding, exact)
    hash = sweep_mix(hash, result.value.to_uint64())
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

