    sweep_digest_exhaustive_bf16_bf16_to_f32_x86_8086_sse(),
    0xBBD0F24EDFF02325UL,
  )
}

///|
fn sweep_digest_exhaustive_bf16_bf16_is_signaling_nan_x86_8086_sse() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<0x10000 {
    let a_bits = index.to_uint16()
    let value = bf16_is_signaling_nan(BF16::from_bits(a_bits))
    hash = sweep_mix(hash, if value { 1UL } else { 0UL })
    hash = sweep_mix(hash, 0UL)
  }
  hash
}

///|
test "golden sweep digest exhaustive_bf16_bf16_is_signaling_nan_x86_8086_sse" {
  @debug.assert_eq(
