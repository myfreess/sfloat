}

///|
fn sweep_digest_exhaustive_f16_f16_to_f64_riscv() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<0x10000 {
    let context = sweep_context(1, NearEven, AfterRounding)
    let a_bits = index.to_uint16()
    let result = f16_to_f64(context, F16::from_bits(a_bits))
    hash = sweep_mix(hash, result.value.to_bits())
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

///|
test "golden sweep digest exhaustive_f16_f16_to_f64_riscv" {
  @debug.assert_eq(
    sweep_digest_exhaustive_f16_f16_to_f64_riscv(),
    0x5040046AB88A2325UL,
  )
}

///|
fn sweep_digest_exhaustive_f16_f16_is_signaling_nan_riscv() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<0x10000 {
    let a_bits = index.to_uint16()
    let value = f16_is_signaling_nan(F16::from_bits(a_bits))
    hash = sweep_mix(hash, if value { 1UL } else { 0UL })
    hash = sweep_mix(hash, 0UL)
  }
  hash
}

///|
test "golden sweep digest exhaustive_f16_f16_is_signaling_nan_riscv" {
  @debug.assert_eq(
    sweep_digest_exhaustive_f16_f16_is_signaling_nan_riscv(),
    0xFF2A5D8F36462325UL,
  )
}

///|
fn sweep_digest_exhaustive_f16_f16_round_to_int_riscv() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<(0x10000 * 4) {
    let rounding = sweep_rounding4(index / 0x10000)
    let context = sweep_context(1, rounding, AfterRounding)
    let exact = true
    let a_bits = (index % 0x10000).to_uint16()
    let result = f16_round_to_int(
      context,
      F16::from_bits(a_bits),
      rounding,
      exact,
    )
    hash = sweep_mix(hash, result.value.to_bits().to_uint64())
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

///|
test "golden sweep digest exhaustive_f16_f16_round_to_int_riscv" {
  @debug.assert_eq(
    sweep_digest_exhaustive_f16_f16_round_to_int_riscv(),
    0x98C6D46255458B25UL,
  )
}
