///|
fn sweep_digest_edge_bf16_bf16_is_signaling_nan_x86_8086_sse() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<18 {
    let a_bits = sweep_edge_f16(index)
    let value = bf16_is_signaling_nan(BF16::from_bits(a_bits))
    hash = sweep_mix(hash, if value { 1UL } else { 0UL })
    hash = sweep_mix(hash, 0UL)
  }
  hash
}

