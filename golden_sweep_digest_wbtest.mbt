///|
fn sweep_digest_exhaustive_f16_f16_round_to_int_x86_8086_sse() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<(0x10000 * 4) {
    let rounding = sweep_rounding4(index / 0x10000)
    let context = sweep_context(0, rounding, AfterRounding)
    let exact = true
    let a_bits = (index % 0x10000).to_uint16()
    let result = f16_round_to_int(
      context,
      F16::from_bits(a_bits),
      rounding,
      exact,
    )
    hash = sweep_mix(hash, result.value.to_bits().to_uint64())
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

