///|
fn sweep_digest_exhaustive_bf16_bf16_to_f32_x86_8086_sse() -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<0x10000 {
    let context = sweep_context(0, NearEven, AfterRounding)
    let a_bits = index.to_uint16()
    let result = bf16_to_f32(context, BF16::from_bits(a_bits))
    hash = sweep_mix(hash, result.value.to_bits().to_uint64())
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

