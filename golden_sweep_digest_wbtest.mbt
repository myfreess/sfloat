  let mut hash = 0xCBF29CE484222325UL
  for index in 0..<2592 {
    let mode_index = index / 324
    let input_index = index % 324
    let rounding = sweep_rounding4(mode_index / 2)
    let tininess = sweep_tininess(mode_index % 2)
    let context = sweep_context(0, rounding, tininess)
    let a_bits = sweep_edge_f64(input_index / 18)
    let b_bits = sweep_edge_f64(input_index % 18)
    let c_bits = sweep_edge_f64(
      (input_index / 18 * 7 + input_index % 18 * 3) % 18,
    )
    let result = f64_mul_add(
      context,
      F64::from_bits(a_bits),
      F64::from_bits(b_bits),
      F64::from_bits(c_bits),
    )
    hash = sweep_mix(hash, result.value.to_bits())
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

///|
test "golden sweep digest edge_f64_f64_mul_add_x86_8086_sse" {
  @debug.assert_eq(
    sweep_digest_edge_f64_f64_mul_add_x86_8086_sse(),
    0xF2B2AF7BF574D97DUL,
  )
}

