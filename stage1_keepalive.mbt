///|
// Stage 1 defines private primitives before arithmetic code calls all of them.
// Reference each staged helper here so `moon check` stays warning-clean without
// widening the public API surface.
fn init {
  ignore(NearEven.softfloat_code())
  ignore(MinMag.softfloat_code())
  ignore(Min.softfloat_code())
  ignore(Max.softfloat_code())
  ignore(NearMaxMag.softfloat_code())
  ignore(Odd.softfloat_code())
  ignore(BeforeRounding.softfloat_code())
  ignore(AfterRounding.softfloat_code())

  ignore(sign_f16_ui(0))
  ignore(exp_f16_ui(0))
  ignore(frac_f16_ui(0))
  ignore(pack_to_f16_ui(false, 0, 0))
  ignore(is_nan_f16_ui(0))
  ignore(sign_bf16_ui(0))
  ignore(exp_bf16_ui(0))
  ignore(frac_bf16_ui(0))
  ignore(pack_to_bf16_ui(false, 0, 0))
  ignore(is_nan_bf16_ui(0))
  ignore(sign_f32_ui(0U))
  ignore(exp_f32_ui(0U))
  ignore(frac_f32_ui(0U))
  ignore(pack_to_f32_ui(false, 0, 0U))
  ignore(is_nan_f32_ui(0U))
  ignore(sign_f64_ui(0UL))
  ignore(exp_f64_ui(0UL))
  ignore(frac_f64_ui(0UL))
  ignore(pack_to_f64_ui(false, 0, 0UL))
  ignore(is_nan_f64_ui(0UL))

  ignore(default_nan_f16_ui(X86_8086SSE))
  ignore(default_nan_f16_ui(RISCV))
  ignore(default_nan_bf16_ui(X86_8086SSE))
  ignore(default_nan_bf16_ui(RISCV))
  ignore(default_nan_f32_ui(X86_8086SSE))
  ignore(default_nan_f32_ui(RISCV))
  ignore(default_nan_f64_ui(X86_8086SSE))
  ignore(default_nan_f64_ui(RISCV))
  ignore(ui32_from_pos_overflow(X86_8086SSE))
  ignore(ui32_from_neg_overflow(RISCV))
  ignore(ui32_from_nan(X86_8086SSE))
  ignore(i32_from_pos_overflow(RISCV))
  ignore(i32_from_neg_overflow(X86_8086SSE))
  ignore(i32_from_nan(RISCV))
  ignore(ui64_from_pos_overflow(X86_8086SSE))
  ignore(ui64_from_neg_overflow(RISCV))
  ignore(ui64_from_nan(X86_8086SSE))
  ignore(i64_from_pos_overflow(RISCV))
  ignore(i64_from_neg_overflow(X86_8086SSE))
  ignore(i64_from_nan(RISCV))

  let x86 = Context::default()
  let riscv = Context::riscv()
  let common = { sign: false, v64: 0UL, v0: 0UL }
  ignore(f16_ui_to_common_nan(x86, 0x7E00))
  ignore(bf16_ui_to_common_nan(x86, 0x7FC0))
  ignore(f32_ui_to_common_nan(x86, 0x7FC00000U))
  ignore(f64_ui_to_common_nan(x86, 0x7FF8000000000000UL))
  ignore(common_nan_to_f16_ui(riscv, common))
  ignore(common_nan_to_bf16_ui(riscv, common))
  ignore(common_nan_to_f32_ui(riscv, common))
  ignore(common_nan_to_f64_ui(riscv, common))
  ignore(propagate_nan_f16_ui(x86, 0x7E00, 0x3C00))
  ignore(propagate_nan_f32_ui(x86, 0x7FC00000U, 0x3F800000U))
  ignore(propagate_nan_f64_ui(x86, 0x7FF8000000000000UL, 0x3FF0000000000000UL))
}
