///|
test "golden vector records smoke" {
  // x86_8086_sse f64_add near_even after 1 3FF0000000000000 3FF0000000000000 4000000000000000 00
  let result0 = @sf.f64_add(
    sweep_context(
      0,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F64::from_bits(0x3FF0000000000000UL),
    @sf.F64::from_bits(0x3FF0000000000000UL),
  )
  @debug.assert_eq(result0.value.to_bits(), 0x4000000000000000UL)
  @debug.assert_eq(result0.context.flags.to_bits(), 0x00U)
  // riscv f64_add near_even after 1 3FF0000000000000 3FF0000000000000 4000000000000000 00
  let result1 = @sf.f64_add(
    sweep_context(
      1,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F64::from_bits(0x3FF0000000000000UL),
    @sf.F64::from_bits(0x3FF0000000000000UL),
  )
  @debug.assert_eq(result1.value.to_bits(), 0x4000000000000000UL)
  @debug.assert_eq(result1.context.flags.to_bits(), 0x00U)
  // x86_8086_sse f32_to_bf16 near_even after 1 3F800000 3F80 00
  let result2 = @sf.f32_to_bf16(
    sweep_context(
      0,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F32::from_bits(0x3F800000U),
  )
  @debug.assert_eq(result2.value.to_bits(), 0x3F80)
  @debug.assert_eq(result2.context.flags.to_bits(), 0x00U)
  // riscv f16_to_f32 near_even after 1 7C01 7FC00000 10
  let result3 = @sf.f16_to_f32(
    sweep_context(
      1,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F16::from_bits(0x7C01),
  )
  @debug.assert_eq(result3.value.to_bits(), 0x7FC00000U)
  @debug.assert_eq(result3.context.flags.to_bits(), 0x10U)
  // x86_8086_sse f64_to_i64 near_even after 1 7FF8000000000000 8000000000000000 10
  let result4 = @sf.f64_to_i64(
    sweep_context(
      0,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F64::from_bits(0x7FF8000000000000UL),
    @sf.RoundingMode::NearEven,
    true,
  )
  @debug.assert_eq(result4.value, 0x8000000000000000UL.reinterpret_as_int64())
  @debug.assert_eq(result4.context.flags.to_bits(), 0x10U)
  // riscv f64_to_i64 near_even after 1 7FF8000000000000 7FFFFFFFFFFFFFFF 10
  let result5 = @sf.f64_to_i64(
    sweep_context(
      1,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F64::from_bits(0x7FF8000000000000UL),
    @sf.RoundingMode::NearEven,
    true,
  )
  @debug.assert_eq(result5.value, 0x7FFFFFFFFFFFFFFFUL.reinterpret_as_int64())
  @debug.assert_eq(result5.context.flags.to_bits(), 0x10U)
  // x86_8086_sse f16_add near_even after 1 3C00 3C00 4000 00
  let result6 = @sf.f16_add(
    sweep_context(
      0,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F16::from_bits(0x3C00),
    @sf.F16::from_bits(0x3C00),
  )
  @debug.assert_eq(result6.value.to_bits(), 0x4000)
  @debug.assert_eq(result6.context.flags.to_bits(), 0x00U)
  // x86_8086_sse f32_div near_even after 1 3F800000 40400000 3EAAAAAB 01
  let result7 = @sf.f32_div(
    sweep_context(
      0,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F32::from_bits(0x3F800000U),
    @sf.F32::from_bits(0x40400000U),
  )
  @debug.assert_eq(result7.value.to_bits(), 0x3EAAAAABU)
  @debug.assert_eq(result7.context.flags.to_bits(), 0x01U)
  // x86_8086_sse f64_sqrt near_even after 1 4000000000000000 3FF6A09E667F3BCD 01
  let result8 = @sf.f64_sqrt(
    sweep_context(
      0,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F64::from_bits(0x4000000000000000UL),
  )
  @debug.assert_eq(result8.value.to_bits(), 0x3FF6A09E667F3BCDUL)
  @debug.assert_eq(result8.context.flags.to_bits(), 0x01U)
  // riscv f64_sqrt near_even after 1 4000000000000000 3FF6A09E667F3BCD 01
  let result9 = @sf.f64_sqrt(
    sweep_context(
      1,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F64::from_bits(0x4000000000000000UL),
  )
  @debug.assert_eq(result9.value.to_bits(), 0x3FF6A09E667F3BCDUL)
  @debug.assert_eq(result9.context.flags.to_bits(), 0x01U)
  // x86_8086_sse f64_mul_add max after 1 3FF0000000000000 3FF0000000000000 0000000000000001 3FF0000000000001 01
  let result10 = @sf.f64_mul_add(
    sweep_context(0, @sf.RoundingMode::Max, @sf.TininessMode::AfterRounding),
    @sf.F64::from_bits(0x3FF0000000000000UL),
    @sf.F64::from_bits(0x3FF0000000000000UL),
    @sf.F64::from_bits(0x0000000000000001UL),
  )
  @debug.assert_eq(result10.value.to_bits(), 0x3FF0000000000001UL)
  @debug.assert_eq(result10.context.flags.to_bits(), 0x01U)
  // riscv f32_eq_signaling near_even after 1 7FC00000 3F800000 0 10
  let result11 = @sf.f32_eq_signaling(
    sweep_context(
      1,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    ),
    @sf.F32::from_bits(0x7FC00000U),
    @sf.F32::from_bits(0x3F800000U),
  )
  @debug.assert_eq(result11.value, false)
  @debug.assert_eq(result11.context.flags.to_bits(), 0x10U)
}

