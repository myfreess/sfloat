///|
fn sweep_digest_exhaustive_bf16_bf16_is_signaling_nan_riscv_range(
  start : Int,
  end : Int,
) -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in start..<end {
    let a_bits = index.to_uint16()
    let value = @sf.bf16_is_signaling_nan(@sf.BF16::from_bits(a_bits))
    hash = sweep_mix(hash, if value { 1UL } else { 0UL })
    hash = sweep_mix(hash, 0UL)
  }
  hash
}
