  end : Int,
) -> UInt64 {
  let mut hash = 0xCBF29CE484222325UL
  for index in start..<end {
    let input_index = index % 18
    let context = sweep_context(
      1,
      @sf.RoundingMode::NearEven,
      @sf.TininessMode::AfterRounding,
    )
    let exact = index / 18 == 1
    let a_bits = sweep_edge_f64(input_index)
    let result = @sf.f64_to_ui64_min_mag(
      context,
      @sf.F64::from_bits(a_bits),
      exact,
    )
    hash = sweep_mix(hash, result.value)
    hash = sweep_mix(hash, result.context.flags.to_bits().to_uint64())
  }
  hash
}

